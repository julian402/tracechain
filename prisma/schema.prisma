generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum LotStatus {
  ACTIVE
  EXPIRED
  QUARANTINE
  DEPLETED
}

enum MovementType {
  CREATED
  TRANSFERRED
  TRANSFORMED
  SPLIT
  MERGED
  STATUS_CHANGED
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

model Plan {
  id            String   @id @default(uuid())
  key           String   @unique
  name          String
  description   String?
  price         Float    @default(0)
  currency      String   @default("USD")
  billingPeriod String   @default("MONTHLY") // MONTHLY | YEARLY | ONE_TIME
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)

  // Límites y features dinámicos (escalables sin migración).
  // limits: { "lots": 10, "users": 3, ... }  (null/ausente = ilimitado)
  // features: { "reports": true, "inspections": false, ... }
  limits   Json @default("{}")
  features Json @default("{}")

  // Preparado para Stripe (sin uso todavía).
  stripeProductId String?
  stripePriceId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations Organization[]
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  status    OrgStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  // Overrides por organización sobre los límites del plan.
  // customLimits: { "lots": 20, "users": 5 } (null/ausente = usa el plan base)
  customLimits Json @default("{}")

  users     User[]
  roles     Role[]
  lots      Lot[]
  movements Movement[]
  visits    Visit[]
  auditLogs AuditLog[]
}

model Permission {
  id     String @id @default(uuid())
  key    String @unique
  module String
  action String
  label  String

  roles RolePermission[]
}

model Role {
  id          String   @id @default(uuid())
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  permissions RolePermission[]
  users       User[]

  @@unique([organizationId, name])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  lots      Lot[]
  movements Movement[]
  auditLogs AuditLog[]
  visits    Visit[]

  @@index([organizationId])
}

model Lot {
  id              String    @id @default(uuid())
  code            String    @unique
  qrCode          String    @unique
  name            String
  quantity        Float
  unit            String
  status          LotStatus @default(ACTIVE)
  productionDate  DateTime
  expirationDate  DateTime
  sanitaryRecord  String?
  storageTemp     Float?
  storageHumidity Float?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  parentLotId String?
  parentLot   Lot?    @relation("LotChildren", fields: [parentLotId], references: [id])
  childLots   Lot[]   @relation("LotChildren")

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  movements Movement[]
  auditLogs AuditLog[]
  visits    Visit[]

  @@index([organizationId])
}

model Movement {
  id           String       @id @default(uuid())
  type         MovementType
  description  String
  quantity     Float?
  fromLocation String?
  toLocation   String?
  createdAt    DateTime     @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  lotId       String
  lot         Lot    @relation(fields: [lotId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@index([organizationId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  oldData   Json?
  newData   Json?
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  lotId String?
  lot   Lot?   @relation(fields: [lotId], references: [id])

  @@index([organizationId])
}

enum VisitType {
  AUDITORIA
  INTERVENTORIA
  INSPECCION
}

enum FindingType {
  NO_CONFORMIDAD
  OBSERVACION
  OPORTUNIDAD
}

enum FindingPriority {
  ALTA
  MEDIA
  BAJA
}

model Visit {
  id              String    @id @default(uuid())
  visitType       VisitType
  visitDate       DateTime
  actReference    String?
  auditorEntity   String
  auditorName     String
  auditedProcess  String?
  objective       String?
  responsible     String?
  commitmentDate  DateTime?
  correctiveActions String?
  createdAt       DateTime  @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  lotId           String?
  lot             Lot?      @relation(fields: [lotId], references: [id])

  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id])

  findings        Finding[]

  @@index([organizationId])
}

model Finding {
  id          String          @id @default(uuid())
  type        FindingType
  priority    FindingPriority
  criteria    String?
  description String
  deadline    DateTime?
  createdAt   DateTime        @default(now())

  visitId     String
  visit       Visit           @relation(fields: [visitId], references: [id])
}
